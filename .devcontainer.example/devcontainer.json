// https://containers.dev/implementors/json_reference
{
  "name": "lasuillard/my-project-template",
  "image": "mcr.microsoft.com/devcontainers/base:dev-trixie",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "extraNixConfig": "extra-experimental-features = nix-command flakes"
    },
    // TODO(bootstrap): If project does not use Docker Compose for dependent services such as database or cache, remove this feature
    "ghcr.io/devcontainers/features/docker-in-docker:3": {
      "moby": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        // TODO(bootstrap): Below is just an example configuration. Update it as needed.
        "astral-sh.ty",
        "charliermarsh.ruff",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
